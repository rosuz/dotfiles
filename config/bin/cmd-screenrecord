#!/bin/bash
set -euo pipefail

ACTION="${1:-}"

RECORD_DIR="$HOME/Pictures/Screenrecord"
FILENAME="record_$(date +%Y%m%d_%H%M%S).mp4"

record() {
  mkdir -p "$RECORD_DIR"
  local filepath="$RECORD_DIR/$FILENAME"
  wf-recorder -g "$GEOMETRY" -f "$filepath" &
  notify-send "Recording started" "${MODE:-fullscreen}"
}

case "$ACTION" in
  full)
    MODE="fullscreen"
    mkdir -p "$RECORD_DIR"
    filepath="$RECORD_DIR/$FILENAME"
    wf-recorder -f "$filepath" &
    notify-send "Recording started" "${MODE:-fullscreen}"
    ;;
  selection)
    MODE="selection"
    GEOMETRY=$(slurp) || exit 0
    [[ -z "$GEOMETRY" ]] && exit 0
    record
    ;;
  window)
    ws=$(hyprctl monitors -j | jq -r '.[] | select(.focused == true) | .activeWorkspace.id')
    rects=$(
      hyprctl monitors -j | jq -r --arg ws "$ws" \
        '.[] | select(.activeWorkspace.id == ($ws | tonumber)) | "\(.x),\(.y) \((.width / .scale) | floor)x\((.height / .scale) | floor)"'
      hyprctl clients -j | jq -r --arg ws "$ws" \
        '.[] | select(.workspace.id == ($ws | tonumber)) | "\(.at[0]),\(.at[1]) \(.size[0])x\(.size[1])"'
    )
    wayfreeze & PID=$!
    sleep 0.1
    GEOMETRY=$(echo "$rects" | slurp) || { kill $PID 2>/dev/null; exit 0; }
    kill $PID 2>/dev/null
    [[ -z "$GEOMETRY" ]] && exit 0
    MODE="window"
    record
    ;;
  stop)
    pkill wf-recorder
    notify-send "Recording stopped"
    ;;
  *)
    echo "Usage: cmd-screenrecord <full|selection|window|stop>"
    exit 1
    ;;
esac
