#!/bin/bash

# Usage:
# launch-tui <command> [args...]        -> launch only
# launch-tui focus <command> [args...]  -> launch or focus existing instance

if [ "$1" = "focus" ]; then
    shift
    MODE="focus"
else
    MODE="launch"
fi

CMD="$1"
shift

APP_ID="org.$(basename "$CMD")"

LAUNCH_COMMAND="uwsm-app -- xdg-terminal-exec --app-id=$APP_ID -e $CMD $*"

if [ "$MODE" = "focus" ]; then
    exec launch-or-focus "$APP_ID" "$LAUNCH_COMMAND"
else
    exec setsid $LAUNCH_COMMAND
fi
