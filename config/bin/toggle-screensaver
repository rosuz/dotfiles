#!/bin/bash

STATE_DIR="$HOME/.local/state/dotfiles"
STATE_FILE="$STATE_DIR/screensaver-off"

mkdir -p "$STATE_DIR"

if [[ -f "$STATE_FILE" ]]; then
    rm -f "$STATE_FILE"
    notify-send "Screensaver disabled"
else
    touch "$STATE_FILE"
    xdg-screensaver activate &
    notify-send "Screensaver enabled"
fi
