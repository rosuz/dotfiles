#!/usr/bin/env bash

(
  sleep 0.15

  color=$(hyprpicker 2>/dev/null)
  [[ -z "$color" ]] && exit 0

  hex="${color#\#}"
  [[ ${#hex} -ne 6 ]] && exit 0

  r=$((16#${hex:0:2}))
  g=$((16#${hex:2:2}))
  b=$((16#${hex:4:2}))

  rgb="rgb($r, $g, $b)"
  rgba="rgba($r, $g, $b, 1)"

  printf "%s" "$rgba" | wl-copy
  sleep 0.05
  printf "%s" "$rgb" | wl-copy
  sleep 0.05
  printf "%s" "$color" | wl-copy

  command -v notify-send >/dev/null && notify-send \
    -a "Color Picker" \
    -u low \
    -t 3000 \
    "Copied $color" \
    "$rgb • $rgba"

) &

exit 0
