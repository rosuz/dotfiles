#!/bin/bash
set -euo pipefail

DOTFILES_PATH="$HOME/.local/share/dotfiles"

# Skip service restarts if not inside a Hyprland session
if [[ "$XDG_SESSION_TYPE" == "tty" ]]; then
    exit 0
fi

mkdir -p ~/.config/btop/themes
ln -sf "$DOTFILES_PATH/themes/current/btop.theme" ~/.config/btop/themes/current.theme

mkdir -p ~/.config/mako
ln -sf "$DOTFILES_PATH/themes/current/mako.ini" ~/.config/mako/config

if [[ -d "$DOTFILES_PATH/themes/current/backgrounds" ]]; then
  first_bg=$(ls "$DOTFILES_PATH/themes/current/backgrounds"/*.png "$DOTFILES_PATH/themes/current/backgrounds"/*.jpg 2>/dev/null | head -1)
  if [[ -n "$first_bg" ]]; then
    ln -nsf "backgrounds/$(basename "$first_bg")" "$DOTFILES_PATH/themes/current/background"
  fi
fi

pkill -x hyprpaper 2>/dev/null || true
sleep 0.3
hyprpaper &

pkill -x waybar 2>/dev/null || true
sleep 0.3
waybar &

pkill mako 2>/dev/null || true
sleep 0.3
mako &

pkill swayosd-server 2>/dev/null || true
sleep 0.3
swayosd-server &

hyprctl reload 2>/dev/null || true

notify-send "Theme applied" 2>/dev/null
