#!/bin/bash

mkdir -p ~/.config/btop/themes
ln -sf ~/.local/share/dotfiles/themes/current/btop.theme ~/.config/btop/themes/current.theme

mkdir -p ~/.config/mako
ln -sf ~/.local/share/dotfiles/themes/current/mako.ini ~/.config/mako/config

pkill -x waybar 2>/dev/null || true
sleep 0.3
waybar &

pkill mako 2>/dev/null || true
sleep 0.3
mako &

pkill swayosd-server 2>/dev/null || true
sleep 0.3
swayosd-server &

hyprctl reload 2>/dev/null || true

notify-send "Theme applied" 2>/dev/null
