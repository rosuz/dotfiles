#!/bin/bash
set -euo pipefail

DOTFILES_PATH="$HOME/.local/share/dotfiles"
THEMES_DIR="$DOTFILES_PATH/themes"

if [[ -z "$1" ]]; then
  ls -d "$THEMES_DIR"/*/ | xargs -n1 basename | grep -v -E '^(current|templates|templates-user|next)$'
else
  THEME_NAME="$1"
  THEME_PATH="$THEMES_DIR/$THEME_NAME"

  if [[ ! -d "$THEME_PATH" ]]; then
    echo "Theme '$THEME_NAME' not found"
    exit 1
  fi

  rm -rf "$THEMES_DIR/next"
  mkdir -p "$THEMES_DIR/next"
  cp -r "$THEME_PATH"/* "$THEMES_DIR/next/"

  TARGET=next "$DOTFILES_PATH/bin/generate-theme"

  rm -rf "$THEMES_DIR/current"
  mv "$THEMES_DIR/next" "$THEMES_DIR/current"

  first_bg=$(ls "$THEMES_DIR/current/backgrounds"/*.png "$THEMES_DIR/current/backgrounds"/*.jpg 2>/dev/null | head -1)
  if [[ -n "$first_bg" ]]; then
    ln -nsf "backgrounds/$(basename "$first_bg")" "$THEMES_DIR/current/background"
  fi

  "$DOTFILES_PATH/bin/apply-theme"

  notify-send "Theme switched to $THEME_NAME"
fi
