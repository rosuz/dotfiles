#!/bin/bash
set -euo pipefail
# Display Hyprland keybindings in clean format
# Output: SUPER + RETURN -> Terminal

declare -A MODMASK_MAP
MODMASK_MAP=([1]="SHIFT" [4]="CTRL" [8]="ALT" [64]="SUPER"
  [5]="SHIFT CTRL" [9]="SHIFT ALT" [12]="CTRL ALT"
  [65]="SUPER SHIFT" [68]="SUPER CTRL" [72]="SUPER ALT"
  [73]="SUPER SHIFT ALT" [76]="SUPER CTRL ALT"
  [77]="SUPER SHIFT CTRL ALT")

declare -A KEYCODE_MAP
KEYCODE_MAP=([10]="1" [11]="2" [12]="3" [13]="4" [14]="5"
  [15]="6" [16]="7" [17]="8" [18]="9" [19]="0")

max_width=0
lines=()

while IFS='|' read -r modmask key keycode desc; do
  [[ "$desc" == "—" || "$desc" == "null" || -z "$desc" ]] && continue

  if [[ -n "$key" && "$key" != "null" ]]; then
    display_key="$key"
  elif [[ -n "$keycode" && "$keycode" != "0" && "$keycode" != "null" ]]; then
    display_key="${KEYCODE_MAP[$keycode]:-$keycode}"
  else
    display_key=""
  fi

  if [[ -n "$display_key" ]]; then
    mod_str="${MODMASK_MAP[$modmask]:-}"
    [[ -n "$mod_str" ]] && combo="$mod_str + $display_key" || combo="$display_key"
  else
    combo="${MODMASK_MAP[$modmask]:-$modmask}"
  fi

  [[ ${#combo} -gt $max_width ]] && max_width=${#combo}
  lines+=("$combo|$desc")
done < <(hyprctl -j binds 2>/dev/null | jq -r '.[] | select(.mouse == false) | "\(.modmask // 0)|\(.key // "")|\(.keycode // "")|\(.description // "")"')

for entry in "${lines[@]}"; do
  combo="${entry%%|*}"
  desc="${entry#*|}"
  printf "%-${max_width}s -> %s\n" "$combo" "$desc"
done
