#!/bin/bash
set -euo pipefail

DOTFILES_PATH="$HOME/.local/share/dotfiles"
THEMES_DIR="$DOTFILES_PATH/themes"
CURRENT_LINK="$THEMES_DIR/current/background"
WALLPAPER_DIR="$THEMES_DIR/current/backgrounds"

if [[ ! -d "$WALLPAPER_DIR" ]]; then
  notify-send "No backgrounds directory found" -t 2000
  exit 1
fi

shopt -s nullglob
wallpapers=("$WALLPAPER_DIR"/*.png "$WALLPAPER_DIR"/*.jpg)
shopt -u nullglob

if ((${#wallpapers[@]} == 0)); then
  notify-send "No wallpapers found" -t 2000
  exit 1
fi

if [[ -L "$CURRENT_LINK" ]]; then
  current_target=$(readlink "$CURRENT_LINK")
  current_name=$(basename "$current_target")
else
  current_name=""
fi

for i in "${!wallpapers[@]}"; do
  if [[ "$(basename "${wallpapers[$i]}")" == "$current_name" ]]; then
    prev_idx=$(( (i - 1 + ${#wallpapers[@]}) % ${#wallpapers[@]} ))
    break
  fi
done

new_wallpaper="${wallpapers[$prev_idx]:-}"
if [[ -n "$new_wallpaper" ]]; then
  ln -nsf "backgrounds/$(basename "$new_wallpaper")" "$CURRENT_LINK"
  
  pkill -x hyprpaper 2>/dev/null || true
  sleep 0.3
  hyprpaper &
fi
