#!/usr/bin/env bash

not_impl() {
    notify-send "$1" "need implementation" -u low
}

menu() {
    local prompt="$1"
    local options="$2"
    
    choice=$(echo -e "$options" | rofi -dmenu -p "$prompt" -theme minimal)
    
    if [[ -z "$choice" ]]; then
        return 1
    fi
    echo "$choice"
}

declare -a MENU_STACK=()
current_menu=""

push_menu() {
    if [[ ${#MENU_STACK[@]} -eq 0 ]]; then
        MENU_STACK+=("$1")
    elif [[ "${MENU_STACK[-1]}" != "$1" ]]; then
        MENU_STACK+=("$1")
    fi
}

pop_menu() {
    if [[ ${#MENU_STACK[@]} -gt 1 ]]; then
        unset 'MENU_STACK[-1]'
    fi
}

back_menu() {
    if [[ ${#MENU_STACK[@]} -eq 1 ]] && [[ "${MENU_STACK[-1]}" == "$current_menu" ]]; then
        exit 0
    fi
    pop_menu
    local prev="${MENU_STACK[-1]}"
    $prev
}

show_main_menu() {
    current_menu="show_main_menu"
    push_menu "show_main_menu"
    choice=$(menu "Go" "ůįÄĽ  Apps\nůįßĎ  Learn\nůįĒé  Trigger\nůįźē  Style\nůįėó  Setup\nůįČČ  Install\nůį≠Ć  Remove\nÔÄ°  Update\nůįčô  About\nůįź•  System")
    case "$choice" in
    *Apps*)        rofi -show drun -theme minimal ;;
    *Learn*)       show_learn_menu ;;
    *Trigger*)     show_trigger_menu ;;
    *Style*)       show_style_menu ;;
    *Setup*)       show_setup_menu ;;
    *Install*)     show_install_menu ;;
    *Remove*)      show_remove_menu ;;
    *Update*)      show_update_menu ;;
    *About*)       show_about ;;
    *System*)      show_system_menu ;;
    *)             exit 0 ;;
    esac
}

show_learn_menu() {
    current_menu="show_learn_menu"
    push_menu "show_learn_menu"
    case $(menu "Learn" "ÔĄú  Keybindings\nÔćô  Hyprland\nůį£á  Arch\nůĪÜÉ  Neovim\nůįĎ≤  Bash") in
    *Keybindings)   show_keybind_menu ;;
    *Hyprland*)     xdg-open https://wiki.hyprland.org/ && exit 0 ;;
    *Arch*)         xdg-open https://wiki.archlinux.org/ && exit 0 ;;
    *Neovim*)       xdg-open https://www.lazyvim.org/keymaps && exit 0 ;;
    *Bash*)         xdg-open https://devhints.io/bash && exit 0 ;;
    *)              back_menu ;;
    esac
}

show_keybind_menu()
{
  current_menu="show_keybind_menu"
  push_menu "show_keybind_menu"
  choice=$(menu-keybindings | rofi -dmenu -theme ~/.local/share/dotfiles/config/rofi/keybindings.rasi -p "Keybindings" -i)
  [[ -z "$choice" ]] && back_menu
  notify-send "Keybinding" "$choice"
  exit 0
}

show_trigger_menu() {
    current_menu="show_trigger_menu"
    push_menu "show_trigger_menu"
    case $(menu "Trigger" "ÔÄį  Capture\nůįĒé  Share\nůįźē  Toggle") in
    *Capture*)     show_capture_menu ;;
    *Share*)       show_share_menu ;;
    *Toggle*)      show_toggle_menu ;;
    *)             back_menu ;;
    esac
}

show_capture_menu() {
    current_menu="show_capture_menu"
    push_menu "show_capture_menu"
    case $(menu "Capture" "ÔÄį  Screenshot\nůįēį  Screenrecord\nůįĎĹ  Color") in
    *Screenshot*)      cmd-screenshot selection clipboard && exit 0 ;;
    *Screenrecord*)    show_screenrecord_menu ;;
    *Color*)           hyprpicker-launch && exit 0 ;;
    *)                 back_menu ;;
    esac
}

show_screenrecord_menu() {
    current_menu="show_screenrecord_menu"
    push_menu "show_screenrecord_menu"
    case $(menu "Screenrecord" "ůįēį  Full screen\nůįäĄ  Selection\nůįąě  Window") in
    *Full\ screen*)    cmd-screenrecord full && exit 0 ;;
    *Selection*)       cmd-screenrecord selection && exit 0 ;;
    *Window*)          cmd-screenrecord window && exit 0 ;;
    *)                 back_menu; return ;;
    esac
}

show_share_menu() {
    current_menu="show_share_menu"
    push_menu "show_share_menu"
    case $(menu "Share" "ůįŹ¨  Clipboard\nůįąĒ  File\nůįČč  Folder") in
    *Clipboard*)    cmd-share clipboard ;;
    *File*)         xdg-terminal-exec --app-id=org.terminal -- bash -c "cmd-share file" ;;
    *Folder*)       xdg-terminal-exec --app-id=org.terminal -- bash -c "cmd-share folder" ;;
    *)              back_menu ;;
    esac
}

show_toggle_menu() {
    current_menu="show_toggle_menu"
    push_menu "show_toggle_menu"
    case $(menu "Toggle" "ůįü¨  Nightlight\nůĪęĖ  Idle Lock\nůįćú  Waybar\nůĪā¨  Workspace Layout\nůįź≠  Window Gaps") in
    *Nightlight*)     toggle-nightlight ;;
    *Idle*)           toggle-idle ;;
    *Waybar*)         toggle-waybar ;;
    *Layout*)         hyprland-workspace-layout-toggle ;;
    *Gaps*)           hyprland-workspace-toggle-gaps ;;
    *)                back_menu ;;
    esac
}

show_style_menu() {
    current_menu="show_style_menu"
    push_menu "show_style_menu"
    case $(menu "Style" "ůįłĆ  Theme\nůįĎĻ  Font\nůįÄĽ  Background\nůįćô  Hyprland\nůįčô  About") in
    *Theme*)       show_theme_menu ;;
    *Font*)        not_impl "Font switching" ;;
    *Background*)  theme-bg-next && exit 0 ;;
    *Hyprland*)    ${EDITOR:-nvim} ~/.config/hypr/looknfeel.conf && exit 0 ;;
    *About*)       ${EDITOR:-nvim} ~/.config/hypr/about.conf && exit 0 ;;
    *)             back_menu ;;
    esac
}

show_theme_menu()
{
    current_menu="show_theme_menu"
    selected=$(theme-switch | rofi -dmenu -p "Theme" -i)
    push_menu "show_theme_menu"
    if [[ -n "$selected" ]]; then
        theme-switch "$selected"
        exit 0
    else
        back_menu
    fi
}

show_setup_menu() {
    current_menu="show_setup_menu"
    push_menu "show_setup_menu"
    case $(menu "Setup" "ůįúĆ  Audio\nůį§®  Wifi\nůįāĮ  Bluetooth\nůĪźč  Power Profile\nůįćĻ  Monitors\nÔĄú  Keybindings\nůįćĺ  Input") in
    *Audio*)       launch-audio && exit 0 ;;
    *Wifi*)        launch-wifi && exit 0 ;;
    *Bluetooth*)   launch-bluetooth && exit 0 ;;
    *Power*)       not_impl "Power profile" ;;
    *Monitors*)    edit-config monitors && exit 0 ;;
    *Keybindings*) edit-config keybindings && exit 0 ;;
    *Input*)       edit-config input && exit 0 ;;
    *)             back_menu ;;
    esac
}

show_install_menu() {
    current_menu="show_install_menu"
    push_menu "show_install_menu"
    case $(menu "Install" "ůį£á  Package\nůį£á  AUR\nÔČ®  Web App\nůįłĆ  Theme\nůįÄĽ  Background\nůįĎĻ  Font") in
    *Package*)    not_impl "Install package" ;;
    *AUR*)        not_impl "Install AUR package" ;;
    *Web*)        not_impl "Install web app" ;;
    *Theme*)      not_impl "Install theme" ;;
    *Background*) not_impl "Install background" ;;
    *Font*)       not_impl "Install font" ;;
    *)            back_menu ;;
    esac
}

show_remove_menu() {
    current_menu="show_remove_menu"
    push_menu "show_remove_menu"
    case $(menu "Remove" "ůį£á  Package\nůįłĆ  Theme") in
    *Package*)    not_impl "Remove package" ;;
    *Theme*)      not_impl "Remove theme" ;;
    *)            back_menu ;;
    esac
}

show_update_menu() {
    current_menu="show_update_menu"
    push_menu "show_update_menu"
    case $(menu "Update" "ůįźē  Config\nůį§é  Process\nůįÄ°  All") in
    *Config*)     not_impl "Refresh config" ;;
    *Process*)    not_impl "Restart process" ;;
    *All*)        not_impl "Update all" ;;
    *)            back_menu ;;
    esac
}

show_about() {
    current_menu="show_about"
    push_menu "show_about"
    not_impl "About"
    back_menu
}

show_system_menu() {
    current_menu="show_system_menu"
    push_menu "show_system_menu"
    case $(menu "System" "ůįĆĺ  Lock\nůįí≤  Suspend\nůįćÉ  Logout\nůįúČ  Restart\nůįź•  Shutdown") in
    *Lock*)        lock-screen && exit 0 ;;
    *Suspend*)     systemctl suspend && exit 0 ;;
    *Logout*)      hyprctl dispatch exit && exit 0 ;;
    *Restart*)     systemctl reboot && exit 0 ;;
    *Shutdown*)    systemctl poweroff && exit 0 ;;
    *)             back_menu ;;
    esac
}

show_clipboard_menu() {
    current_menu="show_clipboard_menu"
    push_menu "show_clipboard_menu"
    choice=$(menu "Clipboard" "ůįáĻ  Reset clipboard\n$(cmd-clipboard list 2>/dev/null)")
    
    if [[ "$choice" == "ůįáĻ  Reset"* ]]; then
        cmd-clipboard reset
        show_clipboard_menu
    elif [[ -n "$choice" ]]; then
        id=$(echo "$choice" | awk '{print $1}')
        cmd-clipboard select "$id" && exit 0
    else
        back_menu
    fi
}

case "${1:-}" in
system)    show_system_menu ;;
keybindings) show_keybind_menu ;;
capture)   show_capture_menu ;;
toggle)    show_toggle_menu ;;
style)     show_style_menu ;;
setup)     show_setup_menu ;;
share)     show_share_menu ;;
background) theme-bg-next && exit 0 ;;
theme)     show_style_menu ;;
*)         show_main_menu ;;
esac
